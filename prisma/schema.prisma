generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  password       String?          // Optional for Google login compatibility
  role           String           @default("USER") // "USER" or "ADMIN"
  status         String           @default("PENDING_APPROVAL") // "PENDING_APPROVAL", "APPROVED", "REJECTED"
  dob            DateTime
  phone          String
  community      String           // Sub-community from Okwojo Ngwo
  profilePicture String           // URL to profile picture
  birthCert      String           // URL to birth certificate/ baptism card
  baptismCard    String?          // Optional alternative URL
  googleId       String?          @unique // Google authentication ID
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  payments       Payment[]
  notifications  Notification[]
  verificationCode VerificationCode?
}

model VerificationCode {
  id           String   @id @default(uuid())
  code         String   @unique // 6-digit verification code
  name         String   // Pre-registered name of the member
  isUsed       Boolean  @default(false)
  usedByUserId String?  @unique
  usedByUser   User?    @relation(fields: [usedByUserId], references: [id])
  createdAt    DateTime @default(now())
}

model Due {
  id          String    @id @default(uuid())
  title       String
  description String?
  amount      Float
  dueDate     DateTime
  type        String    // "MONTHLY", "OCCASIONAL", etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[]
}

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  status      String    // "PENDING", "COMPLETED", "FAILED"
  paidAt      DateTime? // Date when admin confirmed the payment
  submittedAt DateTime  @default(now()) // Date when user submitted pay request
  userId      String
  dueId       String
  user        User      @relation(fields: [userId], references: [id])
  due         Due       @relation(fields: [dueId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
}

model Meeting {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}